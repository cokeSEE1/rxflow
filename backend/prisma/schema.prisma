generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// User — 系统用户（四角色）
// ============================================================
model User {
  id            Int       @id @default(autoincrement())
  name          String    @db.VarChar(50)
  phone         String    @unique @db.VarChar(20)
  passwordHash  String    @db.VarChar(255)
  role          String    @db.VarChar(20)
  department    String?   @db.VarChar(50)
  avatar        String?   @db.VarChar(500)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  loginFailCount Int      @default(0)
  lockedUntil   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  prescriptionsCreated   Prescription[]  @relation("AssistantPrescriptions")
  prescriptionsReviewed  Prescription[]  @relation("DoctorPrescriptions")
  prescriptionsDelivered Prescription[]  @relation("CourierDeliveries")
  notifiedById           Prescription[]  @relation("RejectedByDoctor")
  prescriptionsDispensed Prescription[]  @relation("PharmacistDispensing")
  courierExceptions      DeliveryException[]
  rejectionTemplates     RejectionTemplate[]
  notifications          Notification[]
  registrations          Registration[]
  consultations          Consultation[]

  @@index([role])
}

// ============================================================
// Patient — 患者信息
// ============================================================
model Patient {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(50)
  gender         String    @db.VarChar(10)
  age            Int?
  phone          String    @db.VarChar(20)
  address        String    @db.VarChar(500)
  idCard         String?   @db.VarChar(255)
  allergyHistory String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      Int?

  prescriptions    Prescription[]
  registrations    Registration[]
  consultations    Consultation[]
  patientAllergies PatientAllergy[]

  @@index([phone])
  @@index([name])
}

// ============================================================
// Prescription — 处方主表
// ============================================================
model Prescription {
  id              Int       @id @default(autoincrement())
  prescriptionNo  String    @unique @db.VarChar(50)
  patientId       Int
  patient         Patient   @relation(fields: [patientId], references: [id])
  assistantId     Int
  assistant       User      @relation("AssistantPrescriptions", fields: [assistantId], references: [id])
  consultationId  Int?
  consultation    Consultation? @relation(fields: [consultationId], references: [id])
  doctorId        Int?
  doctor          User?     @relation("DoctorPrescriptions", fields: [doctorId], references: [id])
  pharmacistId    Int?
  pharmacist      User?     @relation("PharmacistDispensing", fields: [pharmacistId], references: [id])
  diagnosis       String    @db.Text
  status          String    @default("draft") @db.VarChar(20)
  rejectedReason  String?   @db.Text
  rejectedType    String?   @db.VarChar(20)
  rejectedById    Int?
  rejectedBy      User?     @relation("RejectedByDoctor", fields: [rejectedById], references: [id])
  courierId       Int?
  courier         User?     @relation("CourierDeliveries", fields: [courierId], references: [id])
  trackingNo      String?   @db.VarChar(100)
  deliveryProof   String?   @db.VarChar(500)
  deliveryMethod  String?   @db.VarChar(20)
  note            String?   @db.Text
  contentSnapshot String?   @db.Text
  expiresAt       DateTime?

  // ---- 状态时间戳（精确记录每一步发生时间） ----
  submittedAt    DateTime?
  approvedAt     DateTime?
  rejectedAt     DateTime?
  dispensingAt   DateTime?
  dispensedAt    DateTime?
  pickedUpAt     DateTime?
  deliveredAt    DateTime?
  returnedAt     DateTime?
  revokedAt      DateTime?

  // ---- 重提交标识 ----
  isResubmit    Boolean  @default(false)
  resubmitCount Int      @default(0)

  // ---- 配送增强 ----
  estimatedDelivery      DateTime?
  redeliverRequestedBy   Int?
  redeliverRequestedAt   DateTime?
  redeliverReason        String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items          PrescriptionItem[]
  timeline       PrescriptionTimeline[]
  smsVerifications SmsVerification[]
  deliveryExceptions DeliveryException[]
  versions       PrescriptionVersion[]

  @@index([status])
  @@index([patientId])
  @@index([assistantId])
  @@index([doctorId])
  @@index([courierId])
  @@index([pharmacistId])
  @@index([submittedAt])
  @@index([consultationId])
  @@index([approvedAt])
}

// ============================================================
// PrescriptionItem — 处方药品明细
// ============================================================
model PrescriptionItem {
  id                Int      @id @default(autoincrement())
  prescriptionId    Int
  prescription      Prescription @relation(fields: [prescriptionId], references: [id])
  drugId            Int?
  drug              Drug?    @relation(fields: [drugId], references: [id])
  drugName          String   @db.VarChar(200)
  specification     String   @db.VarChar(100)
  dosage            String   @db.VarChar(50)
  frequency         String   @db.VarChar(20)
  days              Int
  remark            String?  @db.VarChar(500)
  doctorAnnotation  String?  @db.Text
  pharmacistNote    String?  @db.VarChar(500)

  @@index([prescriptionId])
  @@index([drugId])
}

// ============================================================
// PrescriptionTimeline — 处方状态时间线
// ============================================================
model PrescriptionTimeline {
  id              Int      @id @default(autoincrement())
  prescriptionId  Int
  prescription    Prescription @relation(fields: [prescriptionId], references: [id])
  action          String   @db.VarChar(50)
  operatorId      Int
  operatorName    String   @db.VarChar(50)
  detail          String?  @db.Text
  metadata        String?  @db.Text
  createdAt       DateTime @default(now())

  @@index([prescriptionId])
  @@index([createdAt])
}

// ============================================================
// PrescriptionTemplate — 处方模板
// ============================================================
model PrescriptionTemplate {
  id          Int      @id @default(autoincrement())
  assistantId Int
  name        String   @db.VarChar(100)
  diagnosis   String   @db.Text
  items       String   @db.Text
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([assistantId])
}

// ============================================================
// Notification — 站内通知
// ============================================================
model Notification {
  id             Int       @id @default(autoincrement())
  userId         Int
  user           User      @relation(fields: [userId], references: [id])
  type           String    @db.VarChar(50)
  title          String    @db.VarChar(200)
  content        String    @db.Text
  isRead         Boolean   @default(false)
  readAt         DateTime?
  prescriptionId Int?
  createdAt      DateTime  @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

// ============================================================
// SmsVerification — 签收短信验证码（新表）
// ============================================================
model SmsVerification {
  id             Int       @id @default(autoincrement())
  prescriptionId Int
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])
  phone          String    @db.VarChar(20)
  code           String    @db.VarChar(10)
  expiresAt      DateTime
  isVerified     Boolean   @default(false)
  verifiedAt     DateTime?
  attemptCount   Int       @default(0)
  createdAt      DateTime  @default(now())

  @@index([prescriptionId])
  @@index([expiresAt])
}

// ============================================================
// DeliveryException — 配送异常记录（新表）
// ============================================================
model DeliveryException {
  id             Int       @id @default(autoincrement())
  prescriptionId Int
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])
  courierId      Int
  courier        User      @relation(fields: [courierId], references: [id])
  type           String    @db.VarChar(30)
  description    String    @db.Text
  photo          String?   @db.VarChar(500)
  isResolved     Boolean   @default(false)
  resolvedAt     DateTime?
  resolvedById   Int?
  createdAt      DateTime  @default(now())

  @@index([prescriptionId])
  @@index([courierId])
  @@index([type])
}

// ============================================================
// RejectionTemplate — 医生驳回模板（新表）
// ============================================================
model RejectionTemplate {
  id         Int      @id @default(autoincrement())
  doctorId   Int
  doctor     User     @relation(fields: [doctorId], references: [id])
  name       String   @db.VarChar(100)
  content    String   @db.Text
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([doctorId])
}

// ============================================================
// Drug — 药品主数据
// ============================================================
model Drug {
  id                Int      @id @default(autoincrement())
  standardName      String   @db.VarChar(200)
  genericName       String   @db.VarChar(200)
  tradeName         String?  @db.VarChar(200)
  specification     String   @db.VarChar(100)
  manufacturer      String?  @db.VarChar(200)
  approvalNumber    String?  @db.VarChar(100)
  dosageForm        String   @db.VarChar(50)
  insuranceCategory String   @default("self") @db.VarChar(10)
  unit              String   @default("盒") @db.VarChar(20)
  packageQuantity   Int      @default(1)
  referencePrice    Decimal? @db.Decimal(10, 2)
  pinyinInitial     String   @db.VarChar(50)
  searchCode        String   @db.VarChar(200)
  description       String?  @db.Text
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  ingredients      DrugIngredient[]
  contraindications DrugContraindication[]
  interactionsA    DrugInteraction[]  @relation("InteractionDrugA")
  interactionsB    DrugInteraction[]  @relation("InteractionDrugB")
  items            PrescriptionItem[]
  batches          DrugBatch[]

  @@index([isActive])
  @@index([insuranceCategory])
  @@index([dosageForm])
  @@index([pinyinInitial])
  @@index([genericName])
  @@unique([genericName, specification, manufacturer])
}

// ============================================================
// DrugIngredient — 药品主要成分
// ============================================================
model DrugIngredient {
  id         Int      @id @default(autoincrement())
  drugId     Int
  drug       Drug     @relation(fields: [drugId], references: [id], onDelete: Cascade)
  allergenId Int
  allergen   Allergen @relation(fields: [allergenId], references: [id])
  amount     String?  @db.VarChar(50)

  @@unique([drugId, allergenId])
  @@index([allergenId])
}

// ============================================================
// Allergen — 过敏原字典
// ============================================================
model Allergen {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  category    String   @db.VarChar(50)
  description String?  @db.Text
  createdAt   DateTime @default(now())

  drugs              DrugIngredient[]
  patientAllergies   PatientAllergy[]

  @@index([category])
}

// ============================================================
// PatientAllergy — 患者-过敏原关联
// ============================================================
model PatientAllergy {
  id         Int      @id @default(autoincrement())
  patientId  Int
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  allergenId Int
  allergen   Allergen @relation(fields: [allergenId], references: [id])
  severity   String?  @db.VarChar(20)
  remark     String?  @db.VarChar(500)
  source     String   @default("manual") @db.VarChar(20)
  createdAt  DateTime @default(now())

  @@unique([patientId, allergenId])
  @@index([patientId])
}

// ============================================================
// DrugContraindication — 药品禁忌症
// ============================================================
model DrugContraindication {
  id          Int     @id @default(autoincrement())
  drugId      Int
  drug        Drug    @relation(fields: [drugId], references: [id], onDelete: Cascade)
  description String  @db.VarChar(500)

  @@index([drugId])
}

// ============================================================
// DrugInteraction — 药品相互作用
// ============================================================
model DrugInteraction {
  id          Int     @id @default(autoincrement())
  drugAId     Int
  drugA       Drug    @relation("InteractionDrugA", fields: [drugAId], references: [id], onDelete: Cascade)
  drugBId     Int
  drugB       Drug    @relation("InteractionDrugB", fields: [drugBId], references: [id], onDelete: Cascade)
  severity    String  @db.VarChar(20)
  description String  @db.VarChar(500)

  @@unique([drugAId, drugBId])
  @@index([drugBId])
}

// ============================================================
// DrugBatch — 药品批号与库存
// ============================================================
model DrugBatch {
  id          Int      @id @default(autoincrement())
  drugId      Int
  drug        Drug     @relation(fields: [drugId], references: [id])
  batchNo     String   @db.VarChar(50)
  quantity    Int      @default(0)
  unitPrice   Decimal? @db.Decimal(10, 2)
  expireDate  DateTime
  receivedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([drugId, batchNo])
  @@index([drugId])
  @@index([expireDate])
  @@index([quantity])
}

// ============================================================
// AuditLog — 审计日志
// ============================================================
model AuditLog {
  id           Int      @id @default(autoincrement())
  userId       Int
  userName     String   @db.VarChar(50)
  userRole     String   @db.VarChar(20)
  action       String   @db.VarChar(50)
  resource     String   @db.VarChar(50)
  resourceId   Int?
  beforeState  String?  @db.VarChar(20)
  afterState   String?  @db.VarChar(20)
  diff         String?  @db.Text
  result       String   @default("success") @db.VarChar(20)
  ipAddress    String?  @db.VarChar(45)
  requestId    String?  @db.VarChar(100)
  contentHash  String?  @db.VarChar(64)
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([resource, resourceId])
  @@index([action])
  @@index([createdAt])
}

// ============================================================
// PrescriptionVersion — 处方版本快照
// ============================================================
model PrescriptionVersion {
  id             Int      @id @default(autoincrement())
  prescriptionId Int
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])
  version        Int
  contentHash    String   @db.VarChar(64)
  contentJson    String   @db.Text
  createdBy      Int
  createdByName  String   @db.VarChar(50)
  reason         String?  @db.VarChar(100)
  createdAt      DateTime @default(now())

  @@unique([prescriptionId, version])
  @@index([prescriptionId])
  @@index([contentHash])
}

// ============================================================
// Registration — 挂号记录
// ============================================================
model Registration {
  id          Int      @id @default(autoincrement())
  patientId   Int
  patient     Patient  @relation(fields: [patientId], references: [id])
  doctorId    Int
  doctor      User     @relation(fields: [doctorId], references: [id])
  department  String   @db.VarChar(50)
  registeredAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  consultations Consultation[]

  @@index([patientId])
  @@index([doctorId])
  @@index([registeredAt])
}

// ============================================================
// Consultation — 问诊记录
// ============================================================
model Consultation {
  id              Int      @id @default(autoincrement())
  registrationId  Int?
  registration    Registration? @relation(fields: [registrationId], references: [id])
  patientId       Int
  patient         Patient  @relation(fields: [patientId], references: [id])
  doctorId        Int
  doctor          User     @relation(fields: [doctorId], references: [id])
  chiefComplaint  String   @db.Text
  presentIllness  String?  @db.Text
  pastHistory     String?  @db.Text
  physicalExam    String?  @db.Text
  auxiliaryExam   String?  @db.Text
  diagnosis       String   @db.Text
  icdCode         String?  @db.VarChar(20)
  treatmentPlan   String?  @db.Text
  status          String   @default("draft") @db.VarChar(20)
  stepsCompleted  Json     @default("[\"chiefComplaint\", \"diagnosis\"]")
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  prescriptions Prescription[]

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
}
